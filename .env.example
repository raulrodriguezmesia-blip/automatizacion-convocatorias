# Convocatoria AI Engine - Environment Configuration
# Copy this file to .env and fill in your values

# Environment: development, staging, production
ENV=development

# Logging
LOG_LEVEL=DEBUG
LOG_FORMAT=json

# API Server
API_HOST=0.0.0.0
API_PORT=8000

# OpenTelemetry
OTEL_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_SERVICE_NAME=convocatorias-ai
OTEL_SERVICE_VERSION=1.0.0

# OpenAI/Azure OpenAI (for LLM features)
OPENAI_API_KEY=
OPENAI_API_BASE=
OPENAI_API_VERSION=
OPENAI_MODEL=gpt-4o-mini

# Google Calendar
GOOGLE_CREDENTIALS_PATH=/run/secrets/google-credentials.json
GOOGLE_CALENDAR_ID=primary

# Microsoft Teams/Outlook
TEAMS_WEBHOOK_URL=
OUTLOOK_CLIENT_ID=
OUTLOOK_CLIENT_SECRET=
OUTLOOK_TENANT_ID=

# Database
DATABASE_URL=sqlite:///data/convocatorias.db

# Redis (optional - for caching and rate limiting)
REDIS_URL=redis://localhost:6379

# Circuit breaker Settings
CIRCUIT_FAILURE_THRESHOLD=5
CIRCUIT_RECOVERY_TIMEOUT=60.0
API_RETRY_ATTEMPTS=3
API_RETRY_BACKOFF=1.0

# Rate limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# Security (required for production)
SECRET_KEY=your-secret-key-change-in-production

# Metrics
METRICS_PORT=8000
METRICS_PATH=/metrics
