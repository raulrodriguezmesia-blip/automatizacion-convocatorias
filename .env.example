# Convocatorias Platform - Environment Variables Template
# Copie este archivo a .env y complete los valores según su entorno

# ===== BASE DE DATOS =====
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/convocatorias
SPRING_DATASOURCE_USERNAME=convocatorias
SPRING_DATASOURCE_PASSWORD=convocatorias

# ===== GOOGLE CALENDAR API =====
GOOGLE_CALENDAR_CREDENTIALS=./credentials/google-service-account.json

# ===== MICROSOFT GRAPH API =====
MICROSOFT_GRAPH_CLIENT_ID=your-microsoft-graph-client-id
MICROSOFT_GRAPH_CLIENT_SECRET=your-microsoft-graph-client-secret
MICROSOFT_GRAPH_TENANT_ID=your-tenant-id

# ===== SLACK INTEGRATION =====
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK

# ===== MICROSOFT TEAMS INTEGRATION =====
TEAMS_WEBHOOK_URL=https://outlook.office.com/webhook/your-teams-webhook

# ===== EMAIL (SMTP) =====
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@convocatorias.edu

# ===== HASHICORP VAULT (PRODUCCIÓN) =====
VAULT_ADDR=https://vault.your-company.com
VAULT_TOKEN=your-vault-token

# ===== OPEN TELEMETRY =====
OTEL_EXPORTER_JAEGER_ENDPOINT=http://localhost:14250
OTEL_EXPORTER_PROMETHEUS_PORT=9464
OTEL_SERVICE_NAME=convocatorias-platform
OTEL_ENVIRONMENT=development

# ===== AI SERVICE CONFIGURATION =====
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_MAX_TOKENS=2000
OPENAI_TEMPERATURE=0.7

# ===== FEATURE FLAGS =====
FEATURE_AI_DRAFT=true
FEATURE_CHATBOT=true
FEATURE_NOTIFICATIONS=true
FEATURE_REPORTS=true

# ===== LOGGING =====
LOG_LEVEL=INFO
LOG_FORMAT=json

# ===== SECURITY =====
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRATION_HOURS=24
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# ===== APPLICATION =====
SERVER_PORT=8080
CONTEXT_PATH=/api
FILE_UPLOAD_MAX_SIZE=10MB
TEMPLATE_STORAGE_PATH=./templates